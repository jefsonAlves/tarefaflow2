{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A user task or reminder",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "hasDueDate": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done", "archived", "pending", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "category": { "type": "string" },
        "source": { "type": "string", "enum": ["local", "classroom", "tasks"] },
        "externalId": { "type": "string" },
        "courseId": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "submissionStatus": { "type": "string" },
        "assignedGrade": { "type": "number" },
        "maxPoints": { "type": "number" },
        "alternateLink": { "type": "string" },
        "calendarEventId": { "type": "string" },
        "order": { "type": "number" },
        "subjectId": { "type": "string" },
        "termId": { "type": "string" },
        "localNote": { "type": "string" },
        "lastSyncAt": { "type": "string", "format": "date-time" },
        "updateTime": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "userId", "completed", "source"]
    },
    "UserConfig": {
      "title": "User Configuration",
      "description": "User preferences and sync status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "syncEnabled": { "type": "boolean" },
        "classroomEnabled": { "type": "boolean" },
        "diagnostics": {
          "type": "object",
          "properties": {
            "lastCheck": { "type": "string", "format": "date-time" },
            "notificationsEnabled": { "type": "boolean" },
            "batteryOptimized": { "type": "boolean" }
          }
        }
      }
    }
  },
  "firestore": {
    "tasks": {
      "schema": "Task",
      "description": "User tasks collection"
    },
    "users": {
      "schema": "UserConfig",
      "description": "User settings and metadata"
    }
  }
}
